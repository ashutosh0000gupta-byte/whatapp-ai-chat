# WhatsApp Mode: 'web' = QR scan (Baileys) | 'meta' = Meta Cloud API
WA_MODE=web

# Database Mode: 'local' = db.json file database | 'postgres' = direct PostgreSQL connection
DB_MODE=local

# Server
PORT=3000

# ── Database & Cache Connections (Railway auto-injects in production) ──
# DATABASE_URL=postgresql://postgres:password@localhost:5432/businessflow
# REDIS_URL=redis://default:password@localhost:6379

# ── Google Gemini AI ──────────────────────────────────────────
# Fill with your Gemini API key from Google AI Studio
GEMINI_API_KEY=AQ.Ab8RN6K4j2HivWfTdOMQvc1WtSX-IwiLVCfanusUz38QDARSjA
GEMINI_MODEL=gemini-2.0-flash

# ── n8n Integration Webhook ──────────────────────────────────
# N8N_WEBHOOK_BASE_URL=https://your-n8n-domain.up.railway.app/webhook
N8N_ENABLED=true

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_ORIGIN=http://localhost:5173
