# ─────────────────────────────────────────────────────────────
#  WhatsApp CRM AI — Environment Variables
#  Copy this file to .env and fill in your actual values.
# ─────────────────────────────────────────────────────────────

# WhatsApp Mode: 'web' = QR scan (no credentials needed) | 'meta' = Meta Cloud API
WA_MODE=web

# Server
PORT=3000

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── Google Gemini AI ──────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ── Meta WhatsApp Cloud API ───────────────────────────────────
META_ACCESS_TOKEN=your-whatsapp-permanent-access-token
META_PHONE_NUMBER_ID=your-phone-number-id
META_API_VERSION=v20.0

# ── Webhook Verification ──────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=choose-a-strong-random-string

# ── Restaurant Branding ───────────────────────────────────────
RESTAURANT_NAME=My Restaurant
RESTAURANT_PHONE=+91XXXXXXXXXX

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_ORIGIN=http://localhost:5173
